{
  "name": "tiktok-moderation-backend",
  "version": "2.0.0",
  "description": "TikTok Live comment moderation backend — Trust & Safety Engineering demo",
  "main": "server.js",
  "type": "commonjs",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "jest --runInBand",
    "test:watch": "jest --watch --runInBand"
  },
  "dependencies": {
    "better-sqlite3": "^9.4.3",
    "cors": "^2.8.5",
    "express": "^4.22.1",
    "express-rate-limit": "^7.2.0",
    "socket.io": "^4.7.5",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "nodemon": "^3.1.11",
    "supertest": "^6.3.4"
  },
  "jest": {
    "testEnvironment": "node",
    "roots": [
      "<rootDir>/../tests"
    ],
    "testMatch": [
      "**/*.test.js"
    ],
    "moduleDirectories": [
      "node_modules",
      "<rootDir>/node_modules"
    ]
  }
}
